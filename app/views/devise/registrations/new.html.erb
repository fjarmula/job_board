<h2>Recruiter Sign Up</h2>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="field">
    <%= f.label :first_name %><br />
    <%= f.text_field :first_name, autofocus: true, autocomplete: "first-name" %>
  </div>

  <div class="field">
    <%= f.label :last_name %><br />
    <%= f.text_field :last_name, autocomplete: "last-name" %>
  </div>

  <div class="field">
    <%= f.label :company, "Company Name" %><br />
    <%= f.text_field :company, autocomplete: "company",
                     data: { controller: "company" } %>
    <small id="company-status" style="display: none; margin-top: 5px;"></small>
  </div>

  <!-- Additional company fields (initially hidden) -->
  <div id="new-company-fields" style="display: none;">
    <h3>Company Information</h3>
    <p><em>Please provide additional details about your company</em></p>

    <div class="field">
      <%= label_tag :company_description, "Company Description" %><br />
      <%= text_area_tag :company_description, nil, rows: 4, placeholder: "Brief description of your company..." %>
    </div>

    <div class="field">
      <%= label_tag :company_website, "Website" %><br />
      <%= text_field_tag :company_website, nil, placeholder: "https://example.com" %>
    </div>

    <div class="field">
      <%= label_tag :company_industry, "Industry" %><br />
      <%= text_field_tag :company_industry, nil, placeholder: "e.g., Technology, Healthcare, Finance" %>
    </div>

    <div class="field">
      <%= label_tag :company_size, "Company Size" %><br />
      <%= select_tag :company_size, options_for_select(Company::SIZES), include_blank: "Select company size..." %>
    </div>

    <div class="field">
      <%= label_tag :company_founded_in, "Founded In" %><br />
      <%= number_field_tag :company_founded_in, nil, min: 1800, max: Date.current.year, placeholder: "e.g., 2010" %>
    </div>

    <div class="field">
      <%= label_tag :company_headquarters, "Headquarters" %><br />
      <%= text_field_tag :company_headquarters, nil, placeholder: "e.g., San Francisco, CA" %>
    </div>
  </div>

  <div class="field">
    <%= f.label :email %><br />
    <%= f.email_field :email, autocomplete: "email" %>
  </div>

  <div class="field">
    <%= f.label :password %>
    <% if @minimum_password_length %>
      <em>(<%= @minimum_password_length %> characters minimum)</em>
    <% end %><br />
    <%= f.password_field :password, autocomplete: "new-password" %>
  </div>

  <div class="field">
    <%= f.label :password_confirmation %><br />
    <%= f.password_field :password_confirmation, autocomplete: "new-password" %>
  </div>

  <div class="actions">
    <%= f.submit "Sign up" %>
  </div>
<% end %>

<%= render "devise/shared/links" %>

<script>
    document.addEventListener('turbo:load', function() {
        const companyField = document.querySelector('input[name="recruiter[company]"]');
        const newCompanyFields = document.getElementById('new-company-fields');
        const companyStatus = document.getElementById('company-status');
        let checkTimeout;

        function checkCompanyExists(companyName) {
            if (companyName.length < 2) {
                hideCompanyFields();
                companyStatus.style.display = 'none';
                return;
            }

            fetch(`/companies/check_exists?name=${encodeURIComponent(companyName)}`)
                .then(response => response.json())
                .then(data => {
                    if (data.exists) {
                        // Company exists - hide additional fields
                        hideCompanyFields();
                        companyStatus.textContent = '✓ This company already exists in our system';
                        companyStatus.style.color = 'green';
                        companyStatus.style.display = 'block';
                    } else {
                        // Company doesn't exist - show additional fields
                        showCompanyFields();
                        companyStatus.textContent = 'This appears to be a new company. Please provide additional details.';
                        companyStatus.style.color = 'blue';
                        companyStatus.style.display = 'block';
                    }
                })
                .catch(error => {
                    console.error('Error checking company:', error);
                    // On error, assume it's a new company to be safe
                    showCompanyFields();
                });
        }

        function showCompanyFields() {
            newCompanyFields.style.display = 'block';
        }

        function hideCompanyFields() {
            newCompanyFields.style.display = 'none';
        }

        function debounceCheck() {
            clearTimeout(checkTimeout);
            checkTimeout = setTimeout(() => {
                const companyName = companyField.value.trim();
                checkCompanyExists(companyName);
            }, 500); // Wait 500ms after user stops typing
        }

        companyField.addEventListener('input', debounceCheck);

        // Initial state
        hideCompanyFields();
    });
</script>