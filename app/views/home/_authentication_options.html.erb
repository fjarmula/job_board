<div class="authentication-options-grid container">
  <div class="auth-card">
    <h2>For Job Seekers</h2>
    <p>Looking for your next challenge? Join our community and find the best roles.</p>
    <div class="actions">
      <%= link_to "Sign up", signup_path, class: "btn btn-primary" %>
      <%= link_to "Sign in", login_path, class: "btn btn-secondary" %>
    </div>
  </div>

  <div class="auth-card">
    <h2>For Recruiters</h2>
    <p>Hiring top talent? Post your job offers and reach thousands of candidates.</p>
    <div class="actions">
      <%= link_to "Sign up", new_recruiter_registration_path, class: "btn btn-primary" %>
      <%= link_to "Sign in", new_recruiter_session_path, class: "btn btn-secondary" %>
    </div>
  </div>
</div>
