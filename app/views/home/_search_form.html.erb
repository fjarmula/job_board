<%= form_with url: root_path, method: :get, local: true do |_| %>
  <div class="search-fields-grid">
    <%= render 'home/search_field',
               name: 'company',
               label: 'Company',
               placeholder: 'e.g., Tech Corp' %>

    <%= render 'home/search_field',
               name: 'position',
               label: 'Position',
               placeholder: 'e.g., Developer' %>

    <%= render 'home/search_select',
               name: 'experience_level',
               label: 'Experience',
               options: [
                 ['Any Level', ''],
                 %w[Junior junior],
                 %w[Mid mid_level],
                 %w[Senior senior]
               ] %>

    <%= render 'home/search_select',
               name: 'work_mode',
               label: 'Mode',
               options: [
                 ['Any Mode', ''],
                 %w[Onsite 0],
                 %w[Remote 1],
                 %w[Hybrid 2]
               ] %>

    <%= render 'home/search_field',
               name: 'location',
               label: 'Location',
               placeholder: 'e.g., Krakow' %>
  </div>

  <div class="search-actions">
    <%= link_to "Clear", root_path, class: "btn btn-secondary" %>
    <%= submit_tag "Search Jobs", name: nil, class: "btn btn-primary" %>
  </div>
<% end %>
