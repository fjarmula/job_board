<div class="welcome-banner" style="background: white; padding: 2rem; border-radius: var(--radius); box-shadow: var(--shadow); border: 1px solid var(--border-color); max-width: 600px; margin: 2rem auto;">
  <% if authenticated? %>
    <%= render "welcome_banner/user" %>
  <% elsif recruiter_signed_in? %>
    <%= render "welcome_banner/recruiter" %>
  <% end %>
</div>
