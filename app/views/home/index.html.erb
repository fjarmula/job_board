<section class="hero">
  <h1>Find Your Next Dream Job</h1>
  <p>Discover thousands of job opportunities from top companies around the world.</p>

  <% if !authenticated? && !recruiter_signed_in? %>
    <%= render "authentication_options" %>
  <% else %>
    <%= render "welcome_banner" %>
  <% end %>
</section>

<div class="search-container">
  <%= render 'home/search_form' %>
</div>

<div class="job-offers-section">
  <%= render 'home/job_offers_list', job_offers: @job_offers %>
</div>
