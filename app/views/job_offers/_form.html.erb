<%= form_with(model: job_offer, local: true) do |f| %>

  <%= render 'shared/error_messages', resource: job_offer %>

  <div class="form-group" style="padding: 1rem; background: var(--bg-color); border: 1px solid var(--border-color); border-radius: var(--radius);">
    <%= render 'job_offers/recruiter_info', company: current_recruiter.company, recruiter: current_recruiter %>
  </div>

  <%= f.hidden_field :company_id, value: current_recruiter.company.id %>

  <div class="form-group">
    <%= f.label :position, "Job Title" %>
    <%= f.text_field :position, placeholder: "e.g., Senior Ruby on Rails Developer" %>
  </div>

  <div class="form-group">
    <%= f.label :location, "Location" %>
    <%= f.text_field :location, placeholder: "e.g., Krakow / Remote" %>
  </div>

  <div class="form-group-grid" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem;">
    <%= render 'job_offers/field_group', f: f %>
  </div>

  <div class="form-group" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
    <div>
      <%= f.label :salary_min, "Salary Minimum" %>
      <%= f.number_field :salary_min, step: 100, placeholder: "e.g., 100000" %>
    </div>
    <div>
      <%= f.label :salary_max, "Salary Maximum" %>
      <%= f.number_field :salary_max, step: 100, placeholder: "e.g., 150000" %>
    </div>
  </div>

  <div class="form-group">
    <%= f.label :description, "Job Description" %>
    <%= f.text_area :description, rows: 12, placeholder:
      "Include: \n• General description\n• Key responsibilities\n• Requirements\n• What we offer\n• Team information" %>
  </div>

  <div class="form-group">
    <%= f.label :tech_stack, "Tech Stack / Tools" %>
    <%= f.text_area :tech_stack, placeholder: "Comma-separated (e.g., Ruby, Rails, PostgreSQL)" %>
  </div>

  <div class="form-actions" style="display: flex; gap: 1rem; justify-content: flex-end;">
    <%= f.submit(job_offer.persisted? ? "Update Job" : "Publish Job", class: "btn btn-primary") %>
    <%= link_to "Cancel", company_path(current_recruiter.company), class: "btn btn-secondary" %>
  </div>
<% end %>
