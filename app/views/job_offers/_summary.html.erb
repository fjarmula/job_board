<div class="job-card-header">
  <div>
    <h3 class="job-card-title"><%= link_to job_offer.position, job_offer %></h3>
    <p style="margin: 0.25rem 0 0; font-weight: 600;">
      <%= link_to job_offer.recruiter.company.name, company_path(job_offer.recruiter.company), style: "color: var(--text-main);" %>
    </p>
  </div>
  <div class="badge badge-blue"><%= job_offer.work_mode.humanize %></div>
</div>

<div class="job-card-meta">
  <span>📍 <%= job_offer.location %></span>
  <span>💼 <%= job_offer.experience_level.humanize %></span>
  <span>📅 Posted <%= time_ago_in_words(job_offer.created_at) %> ago</span>
</div>

<div style="margin-bottom: 1.5rem; color: var(--text-muted); font-size: 0.875rem;">
  <%= truncate(job_offer.description, length: 140) %>
</div>

<div class="job-card-footer">
  <div class="salary">
    <% if job_offer.salary_min || job_offer.salary_max %>
      <%= number_to_currency(job_offer.salary_min, precision: 0) if job_offer.salary_min %>
      <%= " - " if job_offer.salary_min && job_offer.salary_max %>
      <%= number_to_currency(job_offer.salary_max, precision: 0) if job_offer.salary_max %>
    <% else %>
      <span style="color: var(--text-muted); font-weight: normal;">Salary undisclosed</span>
    <% end %>
  </div>

  <div class="actions">
    <% if defined?(current_recruiter) && current_recruiter == job_offer.recruiter %>
       <%#= link_to "Edit", edit_job_offer_path(job_offer), class: "btn btn-secondary" %>
    <% end %>
    <%= link_to "Details", job_offer, class: "btn btn-secondary" %>
  </div>
</div>
