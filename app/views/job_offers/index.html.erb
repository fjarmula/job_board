<div class="job-offers">
  <h1>Job Offers</h1>

  <% if @job_offers.any? %>
    <div class="job-offers-list">
      <% @job_offers.each do |job_offer| %>
        <div class="job-offer">
          <h2><%= job_offer.position %></h2>
          <p><strong>Company:</strong> <%= job_offer.company_name %></p>
          <p><strong>Position:</strong> <%= job_offer.position %></p>
          <p><strong>Location:</strong> <%= job_offer.location %></p>
          <p><strong>Work Mode:</strong> <%= job_offer.work_mode.humanize %></p>
          <p><strong>Work Dimension:</strong> <%= job_offer.work_dimension.humanize %></p>
          <p><strong>Experience:</strong> <%= job_offer.experience_level.humanize %></p>
          <p><strong>Description:</strong> See full job offer <%= link_to "click here", job_offer %></p>

          <% if job_offer.salary_min || job_offer.salary_max %>
            <p><strong>Salary:</strong>
              <%= number_to_currency(job_offer.salary_min) if job_offer.salary_min %>
              <%= " - #{number_to_currency(job_offer.salary_max)}" if job_offer.salary_max %>
            </p>
          <% end %>

          <p><small>Posted: <%= time_ago_in_words(job_offer.created_at) %> ago</small></p>
        </div>
      <% end %>
    </div>
  <% else %>
    <p>No job offers available yet.</p>
  <% end %>
</div>