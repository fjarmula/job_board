<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= content_for(:title) || "Job Board" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Job Board">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
   <%#= render 'layouts/header' %>
  </head>

  <body>
    <header class="navbar">
      <div class="container navbar-content">
        <%= link_to "JobBoard", root_path, class: "logo" %>
        <nav>
          <% if authenticated? %>
            <%= link_to "Jobs", job_offers_path, class: "btn btn-secondary" %>
            <%= link_to "Profile", edit_user_path(Current.user), class: "btn btn-secondary" %>
            <%= button_to "Sign out", logout_path, method: :delete, class: "btn btn-secondary" %>
          <% elsif recruiter_signed_in? %>
            <%= link_to "Dashboard", root_path, class: "btn btn-secondary" %>
            <%= link_to "Profile", edit_recruiter_registration_path, class: "btn btn-secondary" %>
            <%= button_to "Sign out", destroy_recruiter_session_path, method: :delete, class: "btn btn-secondary" %>
          <% else %>
            <%= link_to "Sign in", login_path, class: "btn btn-secondary" %>
            <%= link_to "Sign up", signup_path, class: "btn btn-primary" %>
          <% end %>
        </nav>
      </div>
    </header>

    <main class="container">
      <%= yield %>
    </main>

    <footer class="container" style="margin-top: 5rem; padding-bottom: 3rem; text-align: center; color: var(--text-muted); border-top: 1px solid var(--border-color);">
      <p>&copy; <%= Time.current.year %> JobBoard. All rights reserved.</p>
    </footer>
  </body>
</html>
