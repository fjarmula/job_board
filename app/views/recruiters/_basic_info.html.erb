<div class="info-grid">
  <div class="info-item">
    <div style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); margin-bottom: 0.25rem;">Email</div>
    <span style="font-weight: 600; color: var(--text-main);"><%= recruiter.email %></span>
  </div>
  <div class="info-item">
    <div style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); margin-bottom: 0.25rem;">Joined</div>
    <span style="font-weight: 600; color: var(--text-main);"><%= recruiter.created_at.strftime("%B %Y") %></span>
  </div>
</div>
