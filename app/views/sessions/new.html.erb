<div class="auth-page">
  <div class="auth-form-card">
    <h2>Job Seeker Sign In</h2>

    <% if flash[:alert] %>
      <div class="error-explanation" style="margin-bottom: 1rem;">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <% if flash[:notice] %>
      <div style="background: #ecfdf5; border: 1px solid #a7f3d0; padding: 1rem; border-radius: var(--radius); margin-bottom: 1.5rem; color: #065f46; font-size: 0.875rem;">
        <%= flash[:notice] %>
      </div>
    <% end %>

    <%= form_with url: session_path do |form| %>
      <div class="form-group">
        <%= form.label :email_address, "Email Address" %>
        <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", placeholder: "e.g., alex@example.com", value: params[:email_address] %>
      </div>

      <div class="form-group">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
          <%= form.label :password, style: "margin-bottom: 0;" %>
          <%= link_to "Forgot password?", new_password_path, class: "link-hover", style: "font-size: 0.75rem; color: var(--primary-color);" %>
        </div>
        <%= form.password_field :password, required: true, autocomplete: "current-password", placeholder: "••••••••", maxlength: 72 %>
      </div>

      <div class="form-actions">
        <%= form.submit "Sign In", class: "btn btn-primary" %>
      </div>
    <% end %>

    <div class="auth-footer">
      Don't have an account? <%= link_to "Sign up now", signup_path %>
    </div>
  </div>
</div>
