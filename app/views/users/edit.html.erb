<div class="auth-page">
  <div class="auth-form-card">
    <h2>Edit Profile</h2>

    <%= form_with model: @user do |f| %>
      <% if @user.errors.any? %>
        <div class="error-explanation">
          <h2><%= pluralize(@user.errors.count, "error") %> prohibited this account from being saved:</h2>
          <ul>
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="form-group">
        <%= f.label :username %>
        <%= f.text_field :username, placeholder: "e.g., alex_dev" %>
      </div>

      <div class="form-group">
        <%= f.label :email_address %>
        <%= f.email_field :email_address, placeholder: "e.g., alex@example.com" %>
      </div>

      <div class="form-group">
        <div style="display: flex; align-items: baseline; gap: 0.5rem;">
          <%= f.label :password, "New Password", style: "margin-bottom: 0;" %>
          <span style="font-size: 0.75rem; color: var(--text-muted);">(leave blank if you don't want to change it)</span>
        </div>
        <%= f.password_field :password, placeholder: "••••••••" %>
      </div>

      <div class="form-group">
        <%= f.label :password_confirmation, "Confirm New Password" %>
        <%= f.password_field :password_confirmation, placeholder: "••••••••" %>
      </div>

      <div class="form-actions">
        <%= f.submit "Update Account", class: "btn btn-primary" %>
        <%= link_to "Cancel", root_path, class: "btn btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>
